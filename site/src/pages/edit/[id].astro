---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const files = import.meta.glob('../../../../data/derived/edits/*.json', { eager: true });
  return Object.values(files)
    .map((m) => m.default)
    .filter((e) => e.severity)
    .map((e) => ({ params: { id: e.id }, props: { edit: e } }));
}

const { edit } = Astro.props;
const titleChanged = edit.old_title !== edit.new_title;
---

<Base title={`Edit — ${edit.new_title}`}>
  <p><span class={`badge ${edit.severity}`}>{edit.severity}</span></p>
  {titleChanged ? (
    <h1><del>{edit.old_title}</del><br /><ins>{edit.new_title}</ins></h1>
  ) : (
    <h1>{edit.new_title}</h1>
  )}
  <p style="color: var(--muted); font-size: 0.9rem">
    <a href={edit.url} rel="nofollow noopener">Read the live article at {edit.domain}</a> ·
    {edit.source} · detected {edit.detected_at} · language {edit.lang}
    {edit.similarity != null && <> · semantic similarity {edit.similarity}</>}
    · classified by {edit.adjudicated_by}
  </p>

  <div class="diff">
    <div class="diff-head"><div>Before</div><div>After</div></div>
    {edit.hunks.map((hunk) => (
      <div class="hunk">
        <div class="diff-cols">
          <div>
            <span class="ellipsis">… </span>
            {hunk.ops.map(([tag, text]) =>
              tag === 'ins' ? null : tag === 'del'
                ? <span class="w-del">{text} </span>
                : <span>{text} </span>
            )}
            <span class="ellipsis"> …</span>
          </div>
          <div>
            <span class="ellipsis">… </span>
            {hunk.ops.map(([tag, text]) =>
              tag === 'del' ? null : tag === 'ins'
                ? <span class="w-ins">{text} </span>
                : <span>{text} </span>
            )}
            <span class="ellipsis"> …</span>
          </div>
        </div>
      </div>
    ))}
  </div>

  <h2>Detected signals</h2>
  <table>
    <tbody>
      <tr><td>Changed fraction of text</td><td class="num">{edit.signals.change_ratio}</td></tr>
      <tr><td>Numbers changed</td><td class="num">{edit.signals.numbers_changed.join(', ') || '—'}</td></tr>
      <tr><td>Named entities swapped</td><td class="num">{edit.signals.entities_swapped ? 'yes' : 'no'}</td></tr>
      <tr><td>Quotes deleted</td><td class="num">{edit.signals.quotes_deleted}</td></tr>
      <tr><td>Paragraph blocks added / removed</td>
        <td class="num">{edit.signals.blocks_added} / {edit.signals.blocks_removed}</td></tr>
      <tr><td>Headline changed</td><td class="num">{edit.signals.title_changed ? 'yes' : 'no'}</td></tr>
    </tbody>
  </table>
</Base>
