---
import Base from '../../layouts/Base.astro';
import site from '../../../../data/derived/site.json';

export async function getStaticPaths() {
  const { default: data } = await import('../../../../data/derived/site.json');
  return data.sources.map((s) => ({ params: { domain: s.domain }, props: { source: s } }));
}

const { source } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const edits = site.edits.filter((e) => e.domain === source.domain);
---

<Base title={`${source.source || source.domain} — MemoryHole`}>
  <h1>{source.source || source.domain}</h1>
  <table>
    <tbody>
      <tr><td>Domain</td><td class="num">{source.domain}</td></tr>
      <tr><td>Pages tracked</td><td class="num">{source.tracked}</td></tr>
      <tr><td>Edits recorded</td><td class="num">{source.edits_total}</td></tr>
      <tr><td>Narrative / Factual / Minor / Cosmetic</td>
        <td class="num">{source.by_severity.NARRATIVE} / {source.by_severity.FACTUAL} /
          {source.by_severity.MINOR} / {source.by_severity.COSMETIC}</td></tr>
      <tr><td>Most recent edit</td><td class="num">{source.last_edit || '—'}</td></tr>
    </tbody>
  </table>

  <h2>Edit history</h2>
  {edits.length === 0 && <p>No edits recorded for this source yet.</p>}
  {edits.map((e) => (
    <a class="edit-card" href={`${base}edit/${e.id}/`}>
      <span class={`badge ${e.severity}`}>{e.severity}</span>
      <strong> {e.new_title || e.url}</strong>
      {e.summary && <div class="summary">{e.summary}</div>}
      <div class="meta">detected {e.detected_at}</div>
    </a>
  ))}
</Base>
