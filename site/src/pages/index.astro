---
import Base from '../layouts/Base.astro';
import site from '../../../data/derived/site.json';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';

const byDate = new Map();
for (const e of site.edits) {
  if (!byDate.has(e.date)) byDate.set(e.date, []);
  byDate.get(e.date).push(e);
}
---

<Base title="MemoryHole — silent edits in published news">
  <h1>News gets edited after you read it. This machine notices.</h1>
  <p style="color: var(--muted)">
    Every day MemoryHole re-reads {site.sources.reduce((n, s) => n + s.tracked, 0)} tracked
    pages from {site.sources.length} sources and records what quietly changed.
  </p>

  {site.edits.length === 0 && (
    <p>
      No edits detected yet — the first run only takes baseline snapshots.
      Check back after the next daily run.
    </p>
  )}

  {[...byDate.entries()].map(([date, edits]) => (
    <section>
      <h2>{date}</h2>
      {edits.map((e) => (
        <a class="edit-card" href={`${base}edit/${e.id}/`}>
          <span class={`badge ${e.severity}`}>{e.severity}</span>
          <strong> {e.new_title || e.url}</strong>
          {e.old_title !== e.new_title && (
            <div class="meta">was: <del>{e.old_title}</del></div>
          )}
          {e.summary && <div class="summary">{e.summary}</div>}
          <div class="meta">{e.source} · {e.domain} · detected {e.detected_at}</div>
        </a>
      ))}
    </section>
  ))}

  <h2>Sources</h2>
  <table>
    <thead>
      <tr><th>Source</th><th class="num">Tracked</th><th class="num">Edits</th>
        <th class="num">Narrative</th><th class="num">Factual</th></tr>
    </thead>
    <tbody>
      {site.sources.map((s) => (
        <tr>
          <td><a href={`${base}source/${s.domain}/`}>{s.source || s.domain}</a></td>
          <td class="num">{s.tracked}</td>
          <td class="num">{s.edits_total}</td>
          <td class="num">{s.by_severity.NARRATIVE}</td>
          <td class="num">{s.by_severity.FACTUAL}</td>
        </tr>
      ))}
    </tbody>
  </table>
</Base>
